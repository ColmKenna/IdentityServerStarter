@page "/Admin/Claims"
@model IdentityServerAspNetIdentity.Pages.Admin.Claims.IndexModel
@{
    ViewData["Title"] = "Claims";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2><i class="fas fa-id-card"></i> Claims</h2>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["Warning"] != null)
            {
                <div class="alert alert-warning alert-dismissible fade show" role="alert">
                    @TempData["Warning"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (Model.Claims.Any())
            {
                <div class="card">
                    <div class="card-body">
                        <ck-responsive-table class="table table-striped" mobile-breakpoint="768px">
                            <ck-responsive-thead>
                                <ck-responsive-col-head align="left">Claim Type</ck-responsive-col-head>
                                <ck-responsive-col-head align="center" mobile-align="center" mobile-no-label="true">Actions</ck-responsive-col-head>
                            </ck-responsive-thead>
                            <ck-responsive-tbody>
                                @foreach (var claim in Model.Claims)
                                {
                                    <ck-responsive-row>
                                        <ck-responsive-col>@claim.ClaimType</ck-responsive-col>
                                        <ck-responsive-col class="align-center mobile-align-center" mobile-direction="row" mobile-justify="center">
                                            <a asp-page="/Admin/Claims/Edit" asp-route-claimType="@claim.ClaimType" class="button button-sm button-primary">
                                                <i class="fas fa-users-cog"></i> Manage Users
                                            </a>
                                        </ck-responsive-col>
                                    </ck-responsive-row>
                                }
                            </ck-responsive-tbody>
                        </ck-responsive-table>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> No claims found.
                </div>
            }

            <div class="mt-3">
                <a asp-page="/Admin/Index" class="button button-secondary">
                    <i class="fas fa-arrow-left"></i> Back to Dashboard
                </a>
            </div>
        </div>
    </div>
</div>
