@page "/Admin/Users"
@using IdentityServerAspNetIdentity
@using Microsoft.AspNetCore.Authorization
@model IdentityServerAspNetIdentity.Pages.Admin.Users.Index
@inject IAuthorizationService AuthorizationService
@{
    ViewData["Title"] = "Users";
    var canWrite = (await AuthorizationService.AuthorizeAsync(User, UserPolicyConstants.UsersWrite)).Succeeded;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2><i class="fas fa-users"></i> Users</h2>
                @if (canWrite)
                {
                    <a asp-page="/Admin/Users/Create" class="button button-primary" id="create-user-btn">
                        <i class="fas fa-plus"></i> Create User
                    </a>
                }
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (Model.Users.Any())
            {
                <div class="card">
                    <div class="card-body">
                        <ck-responsive-table class="table table-striped" mobile-breakpoint="768px">
                            <ck-responsive-thead>
                                <ck-responsive-col-head align="left">Username</ck-responsive-col-head>
                                <ck-responsive-col-head align="left">Email</ck-responsive-col-head>
                                <ck-responsive-col-head align="center" mobile-align="center">Email Confirmed</ck-responsive-col-head>
                                <ck-responsive-col-head align="center" mobile-align="center">Lockout Status</ck-responsive-col-head>
                                <ck-responsive-col-head align="center" mobile-align="center">2FA Enabled</ck-responsive-col-head>
                                <ck-responsive-col-head align="center" mobile-align="center" mobile-no-label="true">Actions</ck-responsive-col-head>
                            </ck-responsive-thead>
                            <ck-responsive-tbody>
                                @foreach (var user in Model.Users)
                                {
                                    <ck-responsive-row>
                                        <ck-responsive-col>
                                            <a asp-page="/Admin/Users/Edit" asp-route-userId="@user.Id">@user.UserName</a>
                                        </ck-responsive-col>
                                        <ck-responsive-col>@user.Email</ck-responsive-col>
                                        <ck-responsive-col class="align-center mobile-align-center">
                                            @if (user.EmailConfirmed)
                                            {
                                                <span class="badge bg-success">Yes</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning">No</span>
                                            }
                                        </ck-responsive-col>
                                        <ck-responsive-col class="align-center mobile-align-center">
                                            @switch (user.LockoutStatus)
                                            {
                                                case "Active":
                                                    <span class="badge bg-success">Active</span>
                                                    break;
                                                case "Locked Out":
                                                    <span class="badge bg-warning">Locked Out</span>
                                                    break;
                                                case "Disabled":
                                                    <span class="badge bg-danger">Disabled</span>
                                                    break;
                                            }
                                        </ck-responsive-col>
                                        <ck-responsive-col class="align-center mobile-align-center">
                                            @if (user.TwoFactorEnabled)
                                            {
                                                <span class="badge bg-success">Yes</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">No</span>
                                            }
                                        </ck-responsive-col>
                                        <ck-responsive-col class="align-center mobile-align-center" mobile-direction="row" mobile-justify="center">
                                            <a asp-page="/Admin/Users/Edit" asp-route-userId="@user.Id" class="button button-sm button-primary">
                                                <i class="fas fa-edit"></i> Edit
                                            </a>
                                        </ck-responsive-col>
                                    </ck-responsive-row>
                                }
                            </ck-responsive-tbody>
                        </ck-responsive-table>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> No users found.
                </div>
            }
            <div class="mt-3">
                <a asp-page="/Admin/Index" class="button button-secondary">
                    <i class="fas fa-arrow-left"></i> Back to Dashboard
                </a>
            </div>
        </div>
    </div>
</div>