@page "/Admin/ApiScopes"
@model IdentityServerAspNetIdentity.Pages.Admin.ApiScopes.IndexModel
@{
    ViewData["Title"] = "API Scopes";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2><i class="fas fa-layer-group"></i> API Scopes</h2>
                <a asp-page="/Admin/ApiScopes/Create" class="button button-primary" id="create-api-scope-btn">
                    <i class="fas fa-plus"></i> Create API Scope
                </a>
            </div>

            @if (Model.ApiScopes.Any())
            {
                <div class="card">
                    <div class="card-body">
                        <ck-responsive-table class="table table-striped" mobile-breakpoint="768px">
                            <ck-responsive-thead>
                                <ck-responsive-col-head align="left">Name</ck-responsive-col-head>
                                <ck-responsive-col-head align="left">Display Name</ck-responsive-col-head>
                                <ck-responsive-col-head align="left">Description</ck-responsive-col-head>
                                <ck-responsive-col-head align="center" mobile-align="center">Enabled</ck-responsive-col-head>
                                <ck-responsive-col-head align="center" mobile-align="center" mobile-no-label="true">Actions</ck-responsive-col-head>
                            </ck-responsive-thead>
                            <ck-responsive-tbody>
                                @foreach (var scope in Model.ApiScopes)
                                {
                                    <ck-responsive-row>
                                        <ck-responsive-col><code>@scope.Name</code></ck-responsive-col>
                                        <ck-responsive-col>
                                            @(string.IsNullOrWhiteSpace(scope.DisplayName) ? "No display name" : scope.DisplayName)
                                        </ck-responsive-col>
                                        <ck-responsive-col>
                                            @(string.IsNullOrWhiteSpace(scope.Description) ? "No description" : scope.Description)
                                        </ck-responsive-col>
                                        <ck-responsive-col class="align-center mobile-align-center">
                                            @if (scope.Enabled)
                                            {
                                                <span class="badge bg-success">Enabled</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Disabled</span>
                                            }
                                        </ck-responsive-col>
                                        <ck-responsive-col class="align-center mobile-align-center" mobile-direction="row" mobile-justify="center">
                                            <a asp-page="/Admin/ApiScopes/Edit" asp-route-id="@scope.Id" class="button button-sm button-primary">
                                                <i class="fas fa-edit"></i> Edit
                                            </a>
                                        </ck-responsive-col>
                                    </ck-responsive-row>
                                }
                            </ck-responsive-tbody>
                        </ck-responsive-table>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> No API scopes found.
                </div>
            }

            <div class="mt-3">
                <a asp-page="/Admin/Index" class="button button-secondary">
                    <i class="fas fa-arrow-left"></i> Back to Dashboard
                </a>
            </div>
        </div>
    </div>
</div>
