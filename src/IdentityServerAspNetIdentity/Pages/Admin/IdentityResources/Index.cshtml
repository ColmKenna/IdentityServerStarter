@page "/Admin/IdentityResources"
@model IdentityServerAspNetIdentity.Pages.Admin.IdentityResources.IndexModel
@{
    ViewData["Title"] = "Identity Resources";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2><i class="fas fa-id-badge"></i> Identity Resources</h2>
            </div>

            @if (Model.IdentityResources.Any())
            {
                <div class="card">
                    <div class="card-body">
                        <ck-responsive-table class="table table-striped" mobile-breakpoint="768px">
                            <ck-responsive-thead>
                                <ck-responsive-col-head align="left">Name</ck-responsive-col-head>
                                <ck-responsive-col-head align="left">Display Name</ck-responsive-col-head>
                                <ck-responsive-col-head align="left">Description</ck-responsive-col-head>
                                <ck-responsive-col-head align="center" mobile-align="center">Enabled</ck-responsive-col-head>
                            </ck-responsive-thead>
                            <ck-responsive-tbody>
                                @foreach (var resource in Model.IdentityResources)
                                {
                                    <ck-responsive-row>
                                        <ck-responsive-col><code>@resource.Name</code></ck-responsive-col>
                                        <ck-responsive-col>
                                            @(string.IsNullOrWhiteSpace(resource.DisplayName) ? "No display name" : resource.DisplayName)
                                        </ck-responsive-col>
                                        <ck-responsive-col>
                                            @(string.IsNullOrWhiteSpace(resource.Description) ? "No description" : resource.Description)
                                        </ck-responsive-col>
                                        <ck-responsive-col class="align-center mobile-align-center">
                                            @if (resource.Enabled)
                                            {
                                                <span class="badge bg-success">Enabled</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Disabled</span>
                                            }
                                        </ck-responsive-col>
                                    </ck-responsive-row>
                                }
                            </ck-responsive-tbody>
                        </ck-responsive-table>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> No identity resources found.
                </div>
            }

            <div class="mt-3">
                <a asp-page="/Admin/Index" class="button button-secondary">
                    <i class="fas fa-arrow-left"></i> Back to Dashboard
                </a>
            </div>
        </div>
    </div>
</div>
